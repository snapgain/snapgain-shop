{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/calculator",
      "destination": "https://snapgain.uk/calculator",
      "permanent": true
    },
    {
      "source": "/library",
      "destination": "https://snapgain.uk/library",
      "permanent": true
    },
    {
      "source": "/login",
      "destination": "https://snapgain.uk/auth/login",
      "permanent": true
    },
    {
      "source": "/account",
      "destination": "https://snapgain.uk/account",
      "permanent": true
    },
    {
      "source": "/reader/(.*)",
      "destination": "https://snapgain.uk/library",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
