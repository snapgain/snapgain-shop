{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/read", "destination": "/reader.html" },
    { "source": "/success", "destination": "/success.html" },
    { "source": "/", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
